# Set these on Vercel to enable payment + persistence + distribution.
# Add via `vercel env add STRIPE_SECRET_KEY production` etc.

# Stripe - real money in
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_PRICE_ID=price_xxx                      # a single $9/mo Price object

# Upstash Redis - persistent state for keys and quota
# Free tier at https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXX...

# Discord webhook - send hire-form responses to a channel
# Discord: channel settings -> Integrations -> Webhooks -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Bluesky app - optional autonomous posts
BLUESKY_HANDLE=asset-forge.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Tracking
GA_MEASUREMENT_ID=G-XXXX
PLAUSIBLE_DOMAIN=assetforge.dev

# Service upgrades via /api/upgrade return these as `links`
LEMON_CHECKOUT_LINK=https://assetforge.lemonsqueezy.com/buy/xxx
KOFI_LINK=https://ko-fi.com/assetforge/tiers
